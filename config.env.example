# Copy to config.env and fill in your upstream proxy.
#   cp config.env.example config.env && chmod 600 config.env
#
# Format: http://LOGIN:PASSWORD@HOST:PORT
# Special characters in login/password must be percent-encoded (@ -> %40, : -> %3A, etc.).
CLAUDE_UPSTREAM_PROXY=http://user:pass@proxy.example.com:3128

# Local mixed-port of mihomo (scripts default to 7890).
CLAUDE_RELAY_PORT=7890
